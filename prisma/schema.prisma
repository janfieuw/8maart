generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                  String             @id @default(cuid())
  name                String
  slug                String             @unique
  vatNumber           String?
  phone               String?
  billingStreet       String?
  billingHouseNumber  String?
  billingPostalCode   String?
  billingCity         String?
  billingCountry      String?
  shippingStreet      String?
  shippingHouseNumber String?
  shippingPostalCode  String?
  shippingCity        String?
  shippingCountry     String?
  contactEmail        String?
  subscriptionNumber  String?            @unique
  subscriptionStatus  SubscriptionStatus @default(TRIAL)
  trialStartsAt       DateTime?
  trialEndsAt         DateTime?
  activatedAt         DateTime?
  nextRenewalAt       DateTime?
  deactivatedAt       DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  employees           Employee[]
  scanEvents          ScanEvent[]
  ScanTag             ScanTag[]
  User                User[]

  @@index([name])
  @@index([subscriptionStatus])
}

model Employee {
  id                  String                @id @default(cuid())
  companyId           String
  name                String
  pairCode            String                @unique
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now())
  expectedMode        ExpectedMode          @default(ROSTER)
  dailyMinutes        Int                   @default(480)

  Device              Device[]
  company             Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  EmployeeCalendarDay EmployeeCalendarDay[]
  EmployeeRosterDay   EmployeeRosterDay[]
  scanEvents          ScanEvent[]

  @@index([companyId])
  @@index([name])
}

model Device {
  id          String   @id @default(cuid())
  employeeId  String
  deviceToken String   @unique
  createdAt   DateTime @default(now())

  Employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model ScanEvent {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  scanTagId  String
  type       ScanType
  scannedAt  DateTime @default(now())

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  ScanTag    ScanTag  @relation(fields: [scanTagId], references: [id], onDelete: Cascade)

  @@index([companyId, scannedAt])
  @@index([employeeId, scannedAt])
  @@index([scanTagId, scannedAt])
}

model EmployeeCalendarDay {
  id              String   @id @default(cuid())
  employeeId      String
  date            DateTime @db.Date
  expectedMinutes Int

  Employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
}

model EmployeeRosterDay {
  id              String   @id @default(cuid())
  employeeId      String
  weekday         Int
  expectedMinutes Int

  Employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, weekday])
  @@index([employeeId])
}

model ScanTag {
  id        String        @id @default(cuid())
  secret    String        @unique
  createdAt DateTime      @default(now())
  direction ScanDirection
  companyId String

  ScanEvent ScanEvent[]
  Company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, direction])
  @@index([companyId])
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

enum ScanType {
  IN
  OUT
}

enum ExpectedMode {
  ROSTER
  CALENDAR
}

enum ScanDirection {
  IN
  OUT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  INACTIVE
}