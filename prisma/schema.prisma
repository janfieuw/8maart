generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                    String        @id @default(cuid())
  name                  String
  slug                  String        @unique
  vatNumber             String?
  phone                 String?

  billingStreet         String?
  billingHouseNumber    String?
  billingPostalCode     String?
  billingCity           String?
  billingCountry        String?

  shippingStreet        String?
  shippingHouseNumber   String?
  shippingPostalCode    String?
  shippingCity          String?
  shippingCountry       String?

  contactEmail          String?
  subscriptionNumber    String?       @unique
  subscriptionStatus    SubscriptionStatus @default(TRIAL)
  trialStartsAt         DateTime?
  trialEndsAt           DateTime?
  activatedAt           DateTime?
  nextRenewalAt         DateTime?
  deactivatedAt         DateTime?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  users                 User[]
  employees             Employee[]
  scanLocations         ScanLocation[]
  scanEvents            ScanEvent[]

  @@index([name])
  @@index([subscriptionStatus])
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Employee {
  id           String                @id @default(cuid())
  companyId    String
  name         String
  pairCode     String                @unique
  active       Boolean               @default(true)
  createdAt    DateTime              @default(now())
  expectedMode ExpectedMode          @default(ROSTER)

  company      Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  devices      Device[]
  calendarDays EmployeeCalendarDay[]
  rosterDays   EmployeeRosterDay[]
  scanEvents   ScanEvent[]

  @@index([companyId])
  @@index([name])
}

model Device {
  id          String   @id @default(cuid())
  employeeId  String
  deviceToken String   @unique
  createdAt   DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeRosterDay {
  id              String   @id @default(cuid())
  employeeId      String
  weekday         Int
  expectedMinutes Int

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, weekday])
  @@index([employeeId])
}

model EmployeeCalendarDay {
  id              String   @id @default(cuid())
  employeeId      String
  date            DateTime @db.Date
  expectedMinutes Int

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
}

model ScanLocation {
  id          String        @id @default(cuid())
  companyId   String
  name        String
  location    String?
  createdAt   DateTime      @default(now())

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scanTags    ScanTag[]

  @@unique([companyId, name])
  @@index([companyId])
}

model ScanTag {
  id             String        @id @default(cuid())
  secret         String        @unique
  createdAt      DateTime      @default(now())
  direction      ScanDirection
  scanLocationId String

  scanLocation   ScanLocation  @relation(fields: [scanLocationId], references: [id], onDelete: Cascade)
  scanEvents     ScanEvent[]

  @@unique([scanLocationId, direction])
  @@index([scanLocationId])
}

model ScanEvent {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  scanTagId  String
  type       ScanType
  scannedAt  DateTime @default(now())

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  scanTag    ScanTag  @relation(fields: [scanTagId], references: [id], onDelete: Cascade)

  @@index([companyId, scannedAt])
  @@index([employeeId, scannedAt])
  @@index([scanTagId, scannedAt])
}

enum ExpectedMode {
  ROSTER
  CALENDAR
}

enum ScanDirection {
  IN
  OUT
}

enum ScanType {
  IN
  OUT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  INACTIVE
}